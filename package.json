{
  "name": "praise-impact",
  "private": true,
  "scripts": {
    "build:web": "yarn --cwd apps/web build",
    "build:api": "yarn --cwd services/api build",
    "build:mobile-web": "yarn --cwd apps/mobile build",
    "dev:web": "yarn --cwd apps/web dev",
    "dev:api": "yarn --cwd services/api dev"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "services/*"
    ],
    "nohoist": [
      "**/react-native",
      "**/react-native/**",
      "**/expo",
      "**/expo/**",
      "**/expo-modules-core",
      "**/expo-modules-core/**",
      "**/expo-crypto",
      "**/expo-crypto/**",
      "**/expo-video",
      "**/expo-video/**"
    ]
  }
}
