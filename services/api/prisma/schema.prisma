datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String          @id @default(uuid())
  email           String          @unique
  password        String
  role            Role            @default(USER)
  pushToken       String?
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  prayer_requests PrayerRequest[]
  rsvps           RSVP[]

  @@map("users")
}

model Sermon {
  id            String     @id @default(uuid())
  title         String
  description   String
  video_url     String
  audio_url     String?
  source_type   SourceType
  thumbnail_url String?
  duration      Int? // In seconds
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  @@index([created_at])
  @@map("sermons")
}

model LiveSession {
  id         String    @id @default(uuid())
  is_live    Boolean   @default(false)
  video_id   String?
  started_at DateTime?
  updated_at DateTime  @updatedAt

  @@map("live_sessions")
}

model PrayerRequest {
  id         String   @id @default(uuid())
  userId     String
  content    String
  status     String   @default("pending") // pending | praying | answered
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("prayer_requests")
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  location    String?
  event_date  DateTime
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  rsvps       RSVP[]

  @@index([event_date])
  @@map("events")
}

model RSVP {
  id         String   @id @default(uuid())
  userId     String
  eventId    String
  created_at DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
  @@map("rsvps")
}

model AnalyticsEvent {
  id         String   @id @default(uuid())
  userId     String?
  type       String // view_sermon | start_live | end_live | pause | resume | complete
  sermonId   String?
  meta       Json?
  created_at DateTime @default(now())

  @@index([type])
  @@index([sermonId])
  @@index([created_at])
  @@map("analytics_events")
}

enum Role {
  ADMIN
  USER
}

enum SourceType {
  YOUTUBE
  CLOUDINARY
}
