datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  role       Role     @default(USER)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("users")
}

model Sermon {
  id            String     @id @default(uuid())
  title         String
  description   String
  video_url     String
  source_type   SourceType
  thumbnail_url String?
  duration      Int? // In seconds
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  @@map("sermons")
}

model LiveSession {
  id         String    @id @default(uuid())
  is_live    Boolean   @default(false)
  video_id   String?
  started_at DateTime?
  updated_at DateTime  @updatedAt

  @@map("live_sessions")
}

enum Role {
  ADMIN
  USER
}

enum SourceType {
  YOUTUBE
  CLOUDINARY
}
